// C:\DataFlex Projects\FutbolWebApp1\AppSrc\Posicion.wo
// Posicion
//

Use cWebView.pkg
Use cWebPanel.pkg
Use cWebForm.pkg

Use cposicionDataDictionary.dd

Object oPosicion is a cWebView
    Set piColumnCount to 12
    Set psCaption to "Posicion"
    Set piWidth to 700

    Object oposicion_DD is a cposicionDataDictionary
    End_Object 

    Set Main_DD To oposicion_DD
    Set Server  To oposicion_DD


    Object oWebMainPanel is a cWebPanel
        Set piColumnCount to 12

        Object oposicionID is a cWebForm
            Entry_Item posicion.ID
            Set piColumnSpan to 2
            Set piColumnIndex to 0
            Set peLabelPosition to lpTop
            Set psLabel to "ID"
        End_Object 

        Object oposicionNombre is a cWebForm
            Entry_Item posicion.Nombre
            Set piColumnSpan to 9
            Set piColumnIndex to 0
            Set peLabelPosition to lpTop
            Set psLabel to "Nombre"
        End_Object 
    End_Object 

End_Object 
