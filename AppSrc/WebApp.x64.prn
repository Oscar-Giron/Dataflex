36599>>>>>>>    //
36599>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36599>>>>>>>    //
36599>>>>>>>    //  Params:
36599>>>>>>>    //      dtTime  Time to convert
36599>>>>>>>    //  Returns:
36599>>>>>>>    //      String with "HH:MM:SS" format
36599>>>>>>>    //
36599>>>>>>>    Function TimeToString DateTime dtTime Returns String
36601>>>>>>>        String sHours sMinutes sSeconds
36601>>>>>>>        
36601>>>>>>>        //  Extract parts
36601>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36602>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36603>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36604>>>>>>>        
36604>>>>>>>        //  Fill out with 0
36604>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36607>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36610>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36613>>>>>>>        
36613>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36614>>>>>>>    End_Function
36615>>>>>>>    
36615>>>>>>>    //
36615>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36615>>>>>>>    //
36615>>>>>>>    //  Params:
36615>>>>>>>    //      dtTime  Datetime variable to add time to
36615>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36615>>>>>>>    //  Returns:
36615>>>>>>>    //      dtDateTime with the loaded time
36615>>>>>>>    //
36615>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36617>>>>>>>        String sHours sMinutes sSeconds
36617>>>>>>>        
36617>>>>>>>        //  Extract parts
36617>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36618>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36619>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36620>>>>>>>        
36620>>>>>>>        //  Set to DateTime
36620>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36621>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36622>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36623>>>>>>>        
36623>>>>>>>        Function_Return dtTime
36624>>>>>>>    End_Function
