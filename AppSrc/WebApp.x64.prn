36777>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36779>>>>>>>        UChar[] ucaSalt
36780>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36781>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36784>>>>>>>        
36784>>>>>>>        If (num_arguments > 4) Begin
36786>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36787>>>>>>>        End
36787>>>>>>>>
36787>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36788>>>>>>>    End_Function
36789>>>>>>>    
36789>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36791>>>>>>>        Boolean bRequiresTimeCost
36791>>>>>>>        UInteger uiAlgo uiTimeCost
36791>>>>>>>        Integer iBegin iEnd
36791>>>>>>>        String sSalt
36791>>>>>>>        
36791>>>>>>>        Move 1 to iBegin
36792>>>>>>>        
36792>>>>>>>        // Parse Algo
36792>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36793>>>>>>>        If (not(iEnd)) Function_Return False
36796>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36797>>>>>>>        
36797>>>>>>>        // Parse Salt
36797>>>>>>>        Move (iEnd + 1) to iBegin
36798>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36799>>>>>>>        If (not(iEnd)) Function_Return False
36802>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36803>>>>>>>        
36803>>>>>>>        Case Begin
36803>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36805>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36808>>>>>>>                Move True to bRequiresTimeCost
36809>>>>>>>                Case Break
36810>>>>>>>            Case Else
36810>>>>>>>                Error 8710 "Invalid algorithm selected."
36811>>>>>>>>
36811>>>>>>>                Function_Return False
36812>>>>>>>        Case End
36812>>>>>>>        
36812>>>>>>>        // Parse optional timecost
36812>>>>>>>        If (bRequiresTimeCost) Begin
36814>>>>>>>            Move (iEnd + 1) to iBegin
36815>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36816>>>>>>>            If (not(iEnd)) Function_Return False
36819>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36820>>>>>>>        End
36820>>>>>>>>
36820>>>>>>>        
36820>>>>>>>        // Parse rest hash
36820>>>>>>>        Move (iEnd + 1) to iBegin
36821>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36822>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36825>>>>>>>        
36825>>>>>>>        // Base64Decode
36825>>>>>>>        UChar[] ucaSalt
36826>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36827>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36830>>>>>>>        
36830>>>>>>>        // Create new hash
36830>>>>>>>        String sNewHash
36830>>>>>>>        If (bRequiresTimeCost) Begin
36832>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36834>>>>>>>                Function_Return False 
36835>>>>>>>            End
36835>>>>>>>>
36835>>>>>>>        End
36835>>>>>>>>
36835>>>>>>>        Else Begin
36836>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36838>>>>>>>                Function_Return False 
36839>>>>>>>            End
36839>>>>>>>>
36839>>>>>>>        End
36839>>>>>>>>
36839>>>>>>>        Function_Return (sNewHash = sHash)
36840>>>>>>>    End_Function
36841>>>>>>>    
36841>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36843>>>>>>>        Boolean bRequireTimeCost
36843>>>>>>>        UBigInt ullSize
36843>>>>>>>        UChar[] ucaSalt
36844>>>>>>>        String sSalt
36844>>>>>>>        
36844>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36845>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36846>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36849>>>>>>>        
36849>>>>>>>        Case Begin
36849>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36851>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36852>>>>>>>                Move True to bRequireTimeCost
36853>>>>>>>                Case Break
36854>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36857>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36858>>>>>>>                Move True to bRequireTimeCost
36859>>>>>>>                Case Break
36860>>>>>>>            Case Else
36860>>>>>>>                Error 8710 "Invalid algorithm selected."
36861>>>>>>>>
36861>>>>>>>                Function_Return 0
36862>>>>>>>        Case End
36862>>>>>>>        
36862>>>>>>>        // calculate base64 in a non-floating-manner
36862>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36863>>>>>>>        
36863>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36864>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36865>>>>>>>        If (bRequireTimeCost) Begin
36867>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36868>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36869>>>>>>>        End
36869>>>>>>>>
36869>>>>>>>        Else Begin
36870>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36871>>>>>>>        End
36871>>>>>>>>
36871>>>>>>>        
36871>>>>>>>        Function_Return ullSize
36872>>>>>>>    End_Function
36873>>>>>>>End_Class
36874>>>>>>>
36874>>>>>>>Class cPasswordHasher is a cObject
36875>>>>>>>    
36875>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36876>>>>>>>    
36876>>>>>>>    Procedure Construct_Object
36878>>>>>>>        Forward Send Construct_Object
36880>>>>>>>        
36880>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36881>>>>>>>        Property UInteger   puiSaltSize         16
36882>>>>>>>        
36882>>>>>>>        Property UInteger   puiOptTimeCost      420000
36883>>>>>>>    End_Procedure
36884>>>>>>>    
36884>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36886>>>>>>>        Boolean bOk
36886>>>>>>>        UInteger uiAlgo
36886>>>>>>>        Get peAlgorithm to uiAlgo
36887>>>>>>>        
36887>>>>>>>        Case Begin
36887>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36889>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36892>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36893>>>>>>>                Case Break
36894>>>>>>>            Case Else
36894>>>>>>>                Error 8710 "Invalid algorithm selected."
36895>>>>>>>>
36895>>>>>>>                Function_Return False
36896>>>>>>>        Case End
36896>>>>>>>        
36896>>>>>>>        Function_Return bOk
36897>>>>>>>    End_Function
36898>>>>>>>    
36898>>>>>>>    Function RequiredBufferSize Returns UBigInt
36900>>>>>>>        UBigInt ullSize
36900>>>>>>>        UInteger uiAlgo
36900>>>>>>>        Get peAlgorithm to uiAlgo
36901>>>>>>>        
36901>>>>>>>        Case Begin
36901>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36903>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36906>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36907>>>>>>>                Case Break
36908>>>>>>>            Case Else
36908>>>>>>>                Error 8710 "Invalid algorithm selected."
36909>>>>>>>>
36909>>>>>>>                Function_Return 0
36910>>>>>>>        Case End
36910>>>>>>>        
36910>>>>>>>        Function_Return ullSize
36911>>>>>>>    End_Function
36912>>>>>>>
36912>>>>>>>End_Class
