36913>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36914>>>>>    
36914>>>>>    Procedure Construct_Object
36916>>>>>        Handle hoObj
36916>>>>>        
36916>>>>>        Forward Send Construct_Object
36918>>>>>        
36918>>>>>        Set pbSessionCookieHttpOnly to True
36919>>>>>        
36919>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36920>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36921>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36922>>>>>        
36922>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36923>>>>>        Set phoUserDD to hoObj
36924>>>>>        
36924>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36925>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36926>>>>>        Set phoSessionDD to hoObj
36927>>>>>        
36927>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36928>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36929>>>>>        Set phoCrypto to hoObj
36930>>>>>        
36930>>>>>        Property Boolean pbPasswordHashing True
36931>>>>>        
36931>>>>>        Property Boolean pbCreatingNewSession False
36932>>>>>        Property String psLoginName
36933>>>>>        Property String psUserName ""
36934>>>>>        Property Integer piUserRights 0
36935>>>>>    End_Procedure
36936>>>>>    
36936>>>>>    Procedure End_Construct_Object
36938>>>>>        Forward Send End_Construct_Object
36940>>>>>        
36940>>>>>        Handle hoCrypto
36940>>>>>        Integer iFieldLen
36940>>>>>        If (pbPasswordHashing(Self)) Begin
36942>>>>>            Get phoCrypto to hoCrypto
36943>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36946>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36948>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36949>>>>>>
36949>>>>>            End
36949>>>>>>
36949>>>>>        End
36949>>>>>>
36949>>>>>    End_Procedure
36950>>>>>    
36950>>>>>    Function CreateSession String sRemoteAddress Returns String
36952>>>>>        String sSessionKey
36952>>>>>        Integer iErr
36952>>>>>        Boolean bLogWebSession
36952>>>>>        Handle hoSessionDD       
36952>>>>>        Get phoSessionDD to hoSessionDD
36953>>>>>        
36953>>>>>        //  Get session key
36953>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36955>>>>>        
36955>>>>>        Get pbLogWebSession to bLogWebSession
36956>>>>>        If not bLogWebSession Begin
36958>>>>>            Function_Return sSessionKey        
36959>>>>>        End
36959>>>>>>
36959>>>>>
36959>>>>>        //  Store session
36959>>>>>        Send Clear of hoSessionDD
36960>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36961>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36962>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36963>>>>>        Get Request_Validate of hoSessionDD to iErr
36964>>>>>        If (iErr) Begin
36966>>>>>            // this should not happen. If it does its a programming error
36966>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36967>>>>>>
36967>>>>>            Function_Return ""
36968>>>>>        End
36968>>>>>>
36968>>>>>        Send Request_Save of hoSessionDD
36969>>>>>        If (Err) Begin
36971>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36971>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36972>>>>>>
36972>>>>>            Function_Return ""
36973>>>>>        End
36973>>>>>>
36973>>>>>       
36973>>>>>        Function_Return sSessionKey        
36974>>>>>    End_Function
36975>>>>>    
36975>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36977>>>>>        DateTime dtLastAccess dtCurrent
36977>>>>>        TimeSpan tsDiff
36977>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36977>>>>>        Boolean bResult bCreatingNewSession
36977>>>>>        Boolean bLogWebSession bLoadWebApp
36977>>>>>        Integer eLoginMode
36977>>>>>        String sTime
36977>>>>>        Handle hoSessionDD hoUserDD       
36977>>>>>        
36977>>>>>        Move False to bLoadWebApp
36978>>>>>        If (num_arguments >= 2) Begin
36980>>>>>            Move bOptLoadWebApp to bLoadWebApp
36981>>>>>        End
36981>>>>>>
36981>>>>>        
36981>>>>>        Get phoSessionDD to hoSessionDD
36982>>>>>        Get phoUserDD to hoUserDD
36983>>>>>        
36983>>>>>        Get pbLogWebSession to bLogWebSession
36984>>>>>        Get peLoginMode to eLoginMode
36985>>>>>        
36985>>>>>        // for this object, you can only disable logging if login completely is disabled
36985>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36987>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36988>>>>>>
36988>>>>>            Function_Return False
36989>>>>>        End
36989>>>>>>
36989>>>>>
36989>>>>>        //  Clear session properties
36989>>>>>        Set psSessionKey to ""
36990>>>>>        Send UpdateSessionProperties True
36991>>>>>        
36991>>>>>        If not bLogWebSession Begin
36993>>>>>            Forward Get ValidateSession sSessionKey to bResult
36995>>>>>            Function_Return bResult
36996>>>>>        End        
36996>>>>>>
36996>>>>>        
36996>>>>>        Move False to bResult
36997>>>>>        Get piSessionTimeout to iSessionTimeout 
36998>>>>>        
36998>>>>>        //  Check if session exists
36998>>>>>        Send Clear of hoSessionDD
36999>>>>>        Move sSessionKey to WebAppSession.SessionKey
37000>>>>>        Send Find of hoSessionDD EQ Index.1
37001>>>>>            
37001>>>>>        If (Found) Begin
37003>>>>>            //  Calculate timespan between now and last access time
37003>>>>>            Move (CurrentDateTime()) to dtCurrent
37004>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37005>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37006>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37007>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37008>>>>>            
37008>>>>>            //  Check if session didn't time out
37008>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37010>>>>>                Forward Get ValidateSession sSessionKey to bResult
37012>>>>>                   
37012>>>>>                If (bResult) Begin
37014>>>>>                    //  Update session record
37014>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37015>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37016>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37017>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37018>>>>>                    Get Request_Validate of hoSessionDD to iErr
37019>>>>>                    If (iErr) Begin
37021>>>>>                        // this should not happen. If it does its a programming error
37021>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37022>>>>>>
37022>>>>>                        Function_Return False
37023>>>>>                    End
37023>>>>>>
37023>>>>>                    Send Request_Save of hoSessionDD
37024>>>>>                    
37024>>>>>                    //  Update user properties
37024>>>>>                    Send UpdateSessionProperties False
37025>>>>>                End
37025>>>>>>
37025>>>>>            End
37025>>>>>>
37025>>>>>            Else Begin
37026>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37026>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37027>>>>>                
37027>>>>>                If (not(bCreatingNewSession)) Begin
37029>>>>>                    If (not(bLoadWebApp)) Begin
37031>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37032>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37033>>>>>>
37033>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37034>>>>>                    End
37034>>>>>>
37034>>>>>                    Else Begin
37035>>>>>                        Set pbCreatingNewSession to True                    
37036>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37037>>>>>                        Set pbCreatingNewSession to False                        
37038>>>>>                    End
37038>>>>>>
37038>>>>>                End
37038>>>>>>
37038>>>>>            End
37038>>>>>>
37038>>>>>        End
37038>>>>>>
37038>>>>>        Else Begin
37039>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37040>>>>>>
37040>>>>>        End
37040>>>>>>
37040>>>>>        
37040>>>>>        Function_Return bResult
37041>>>>>    End_Function
37042>>>>>    
37042>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37044>>>>>        If (not(pbPasswordHashing(Self))) Begin
37046>>>>>            Move sPassword to sHash
37047>>>>>            Function_Return True
37048>>>>>        End
37048>>>>>>
37048>>>>>        
37048>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37050>>>>>            Function_Return False
37051>>>>>        End
37051>>>>>>
37051>>>>>        Move ("V1$" + sHash) to sHash
37052>>>>>        Function_Return True
37053>>>>>    End_Function
37054>>>>>    
37054>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37056>>>>>        If (not(pbPasswordHashing(Self))) Begin
37058>>>>>            Move False to bShouldUpgrade
37059>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37060>>>>>        End
37060>>>>>>
37060>>>>>        
37060>>>>>        String sVersion
37060>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37061>>>>>        If (sVersion = "V1$") Begin
37063>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37066>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37067>>>>>        End
37067>>>>>>
37067>>>>>        Else Begin
37068>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37071>>>>>            Function_Return False
37072>>>>>        End
37072>>>>>>
37072>>>>>    End_Function
