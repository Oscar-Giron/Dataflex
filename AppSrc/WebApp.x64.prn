37073>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37075>>>>>        Handle hoUserDD
37075>>>>>        Integer iErr
37075>>>>>        Get phoUserDD to hoUserDD
37076>>>>>        
37076>>>>>        //  Find the user
37076>>>>>        Send Clear of hoUserDD
37077>>>>>        Move sLoginName to WebAppUser.LoginName
37078>>>>>        Send Find of hoUserDD EQ Index.1
37079>>>>>        If (Found) Begin
37081>>>>>            Send Clear of hoUserDD
37082>>>>>            Function_Return False
37083>>>>>        End
37083>>>>>>
37083>>>>>        
37083>>>>>        Send Clear of hoUserDD
37084>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37085>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37086>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37088>>>>>            Send Clear of hoUserDD
37089>>>>>            Function_Return False
37090>>>>>        End
37090>>>>>>
37090>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37091>>>>>        Get Request_Validate of hoUserDD to iErr
37092>>>>>        If (iErr) Begin
37094>>>>>            Send Clear of hoUserDD
37095>>>>>            Function_Return False
37096>>>>>        End
37096>>>>>>
37096>>>>>        
37096>>>>>        Send Request_Save of hoUserDD
37097>>>>>        Function_Return (not(Err))
37098>>>>>    End_Function
37099>>>>>    
37099>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37101>>>>>        String sSessionKey sUserPassword
37101>>>>>        Handle hoSessionDD hoUserDD
37101>>>>>        Boolean bMatch bUpgrade
37101>>>>>        
37101>>>>>        Get phoSessionDD to hoSessionDD
37102>>>>>        Get phoUserDD to hoUserDD
37103>>>>>        Integer iErr eLoginMode
37103>>>>>        
37103>>>>>        // Refind session record
37103>>>>>        Get psSessionKey to sSessionKey
37104>>>>>        Send Clear of hoSessionDD
37105>>>>>        Move sSessionKey to WebAppSession.SessionKey
37106>>>>>        Send Find of hoSessionDD EQ Index.1
37107>>>>>        
37107>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37109>>>>>            Get peLoginMode to eLoginMode
37110>>>>>            
37110>>>>>            //  Find the user
37110>>>>>            Move sLoginName to WebAppUser.LoginName
37111>>>>>            Send Find of hoUserDD EQ Index.1
37112>>>>>            
37112>>>>>            // Check username and password
37112>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37114>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37115>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37116>>>>>                
37116>>>>>                If (bMatch) Begin
37118>>>>>                    // Store the login
37118>>>>>                    If (bUpgrade) Begin
37120>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37121>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37124>>>>>                    End
37124>>>>>>
37124>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37125>>>>>                    Get Request_Validate of hoSessionDD to iErr
37126>>>>>                    If (iErr) Begin
37128>>>>>                        // this should not happen. If it does its a programming error
37128>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37129>>>>>>
37129>>>>>                        Function_Return False
37130>>>>>                    End
37130>>>>>>
37130>>>>>                    
37130>>>>>                    Send Request_Save of hoSessionDD
37131>>>>>                    
37131>>>>>                    // Update session properties
37131>>>>>                    Send UpdateSessionProperties False
37132>>>>>                    Send NotifyChangeRights
37133>>>>>                    Function_Return True
37134>>>>>                End
37134>>>>>>
37134>>>>>                Else Begin
37135>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37135>>>>>                    Send Clear of hoUserDD
37136>>>>>                End
37136>>>>>>
37136>>>>>            End
37136>>>>>>
37136>>>>>            Else Begin
37137>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37137>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37138>>>>>            End
37138>>>>>>
37138>>>>>        End
37138>>>>>>
37138>>>>>        Else Begin
37139>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37139>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37140>>>>>        End
37140>>>>>>
37140>>>>>          
37140>>>>>        Function_Return False
37141>>>>>    End_Function
37142>>>>>    
37142>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37144>>>>>        Handle hoUserDD
37144>>>>>        Integer iErr
37144>>>>>        Get phoUserDD to hoUserDD
37145>>>>>        
37145>>>>>        //  Find the user
37145>>>>>        Send Clear of hoUserDD
37146>>>>>        Move sLoginName to WebAppUser.LoginName
37147>>>>>        Send Find of hoUserDD EQ Index.1
37148>>>>>        If (not(Found)) Begin
37150>>>>>            Send Clear of hoUserDD
37151>>>>>            Function_Return False
37152>>>>>        End
37152>>>>>>
37152>>>>>        
37152>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37154>>>>>            Send Clear of hoUserDD
37155>>>>>            Function_Return False
37156>>>>>        End
37156>>>>>>
37156>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37157>>>>>        Get Request_Validate of hoUserDD to iErr
37158>>>>>        If (iErr) Begin
37160>>>>>            Send Clear of hoUserDD
37161>>>>>            Function_Return False
37162>>>>>        End
37162>>>>>>
37162>>>>>        
37162>>>>>        Send Request_Save of hoUserDD
37163>>>>>        Function_Return (not(Err))
37164>>>>>    End_Function
37165>>>>>    
37165>>>>>    Function IsLoggedIn Returns Boolean
37167>>>>>        String sLoginName
37167>>>>>        Boolean bLogWebSession bLoggedIn
37167>>>>>        
37167>>>>>        Get pbLogWebSession to bLogWebSession
37168>>>>>        If not bLogWebSession Begin
37170>>>>>            Forward Get IsLoggedIn to bLoggedIn
37172>>>>>            Function_Return bLoggedIn
37173>>>>>        End
37173>>>>>>
37173>>>>>        
37173>>>>>        Get psLoginName to sLoginName
37174>>>>>        
37174>>>>>        Function_Return (sLoginName <> "")
37175>>>>>    End_Function
37176>>>>>    
37176>>>>>    
37176>>>>>    //
37176>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37176>>>>>    // update properties based on the session and user data. Augment this function to update 
37176>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37176>>>>>    // the right records when this procedure is called.
37176>>>>>    //
37176>>>>>    // Params:
37176>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37176>>>>>    //
37176>>>>>    Procedure UpdateSessionProperties Boolean bClear
37178>>>>>        Handle hoUserDD
37178>>>>>        
37178>>>>>        Get phoUserDD to hoUserDD
37179>>>>>        
37179>>>>>        //  Update user properties
37179>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37181>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37182>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37183>>>>>            Set piUserRights to WebAppUser.Rights
37184>>>>>            
37184>>>>>            Send OnSessionPropertiesSet 
37185>>>>>        End
37185>>>>>>
37185>>>>>        Else Begin
37186>>>>>            Set psUsername to ""
37187>>>>>            Set psLoginName to ""
37188>>>>>            Set piUserRights to 0
37189>>>>>            
37189>>>>>            Send OnSessionPropertiesClear
37190>>>>>        End
37190>>>>>>
37190>>>>>    End_Procedure
37191>>>>>    
37191>>>>>    Procedure OnSessionPropertiesSet
37193>>>>>        //  Empty event stub
37193>>>>>    End_Procedure
37194>>>>>    
37194>>>>>    Procedure OnSessionPropertiesClear
37196>>>>>        //  Empty event stub
37196>>>>>    End_Procedure
37197>>>>>    
37197>>>>>    Procedure EndSession
37199>>>>>        Integer iErr
37199>>>>>        Boolean bLogWebSession
37199>>>>>        Handle hoSessionDD       
37199>>>>>        
37199>>>>>        Get phoSessionDD to hoSessionDD
37200>>>>>        Get pbLogWebSession to bLogWebSession
37201>>>>>        If not bLogWebSession Begin
37203>>>>>            Forward Send EndSession
37205>>>>>            Procedure_Return
37206>>>>>        End
37206>>>>>>
37206>>>>>            
37206>>>>>        //  Check if session exists
37206>>>>>        Send Clear of hoSessionDD
37207>>>>>        Get psSessionKey to WebAppSession.SessionKey
37208>>>>>        
37208>>>>>        Send Find of hoSessionDD EQ Index.1
37209>>>>>        If (Found) Begin
37211>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37212>>>>>            Get Request_Validate of hoSessionDD to iErr
37213>>>>>            If (iErr) Begin
37215>>>>>                // this should not happen. If it does its a programming error
37215>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37216>>>>>>
37216>>>>>                Procedure_Return
37217>>>>>            End
37217>>>>>>
37217>>>>>            Send Request_Save of hoSessionDD
37218>>>>>        End
37218>>>>>>
37218>>>>>    End_Procedure
37219>>>>>
37219>>>>>End_Class
