36749>>>>>>>                Move True to bRequireTimeCost
36750>>>>>>>                Case Break
36751>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36754>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36755>>>>>>>                If (not(bOk)) Function_Return False
36758>>>>>>>                
36758>>>>>>>                Move True to bRequireTimeCost
36759>>>>>>>                Case Break
36760>>>>>>>            Case Else
36760>>>>>>>                Error 8710 "Invalid algorithm selected."
36761>>>>>>>>
36761>>>>>>>                Function_Return False
36762>>>>>>>        Case End
36762>>>>>>>        
36762>>>>>>>        String sSalt
36762>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36763>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36766>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36767>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36770>>>>>>>        
36770>>>>>>>        If (bRequireTimeCost) Begin
36772>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36773>>>>>>>        End
36773>>>>>>>>
36773>>>>>>>        Else Begin
36774>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36775>>>>>>>        End
36775>>>>>>>>
36775>>>>>>>        
36775>>>>>>>        Function_Return bOk
36776>>>>>>>    End_Function
