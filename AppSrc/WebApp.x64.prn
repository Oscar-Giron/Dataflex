37307>>>    
37307>>>    Procedure DoLogin
37310>>>        String sLoginName sPassword sPrevStateHash
37310>>>        Boolean bResult
37310>>>        
37310>>>        WebGet psValue of oLoginName to sLoginName
37311>>>        WebGet psValue of oPassword to sPassword
37312>>>        
37312>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37313>>>        
37313>>>        If (bResult) Begin
37315>>>            Send Hide of oLogin
37316>>>            Send ShowHeader of ghoWebApp
37317>>>            WebSet psCSSClass of ghoWebApp to ""
37318>>>            
37318>>>            WebGet psPrevStateHash to sPrevStateHash
37319>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37320>>>            
37320>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37320>>>            WebSet psValue of oLoginName to ""
37321>>>            WebSet psValue of oPassword  to ""
37322>>>            WebSet pbVisible of oWarning to False
37323>>>        End
37323>>>>
37323>>>        Else Begin
37324>>>            WebSet pbVisible of oWarning to True
37325>>>        End
37325>>>>
37325>>>    End_Procedure
37326>>>    
37326>>>    Procedure OnSubmit
37329>>>        Send DoLogin
37330>>>    End_Procedure
37331>>>    
37331>>>    Procedure OnLoad
37334>>>        String sPrevStateHash sView
37334>>>        
37334>>>        Forward Send OnLoad
37336>>>        
37336>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37336>>>        Get StateHash of ghoWebApp to sPrevStateHash
37337>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37338>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37340>>>            WebSet psPrevStateHash to sPrevStateHash
37341>>>        End
37341>>>>
37341>>>        
37341>>>    End_Procedure
