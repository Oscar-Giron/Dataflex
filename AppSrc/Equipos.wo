// C:\DataFlex Projects\FutbolWebApp1\AppSrc\Equipos.wo
// Equipos
//

Use cWebView.pkg
Use cWebPanel.pkg
Use cWebForm.pkg

Use cligaDataDictionary.dd
Use cequipoDataDictionary.dd

Object oEquipos is a cWebView
    Set piColumnCount to 12
    Set psCaption to "Equipos"
    Set piWidth to 700

    Object oliga_DD is a cligaDataDictionary
    End_Object 

    Object oequipo_DD is a cequipoDataDictionary
        Set DDO_Server To oliga_DD
    End_Object 

    Set Main_DD To oequipo_DD
    Set Server  To oequipo_DD


    Object oWebMainPanel is a cWebPanel
        Set piColumnCount to 12

        Object oequipoID is a cWebForm
            Entry_Item equipo.ID
            Set piColumnSpan to 2
            Set piColumnIndex to 0
            Set peLabelPosition to lpTop
            Set psLabel to "ID"
        End_Object 

        Object oequipoNombre is a cWebForm
            Entry_Item equipo.Nombre
            Set piColumnSpan to 12
            Set piColumnIndex to 0
            Set peLabelPosition to lpTop
            Set psLabel to "Nombre"
        End_Object 

        Object oligaID is a cWebForm
            Entry_Item liga.ID
            Set piColumnSpan to 2
            Set piColumnIndex to 0
            Set peLabelPosition to lpTop
            Set psLabel to "LigaID"
        End_Object 
    End_Object 

End_Object 
